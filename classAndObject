# ===== BASIC CLASS DEFINITION =====

"""
When we write:  def __init__(self, name, occupation, networth):
                    self.name = name
                    self.occupation = occupation
                    self.networth = networth

'name' (parameter)      = Temporary local variable - only exists in __init__ function
'self.name' (attribute) = Permanent instance variable - belongs to the object forever

Example:
    Person("Sagiruddin", "Developer", 10)
    
    'name' parameter = "Sagiruddin"  (just passing data to function)
    'self.name' attribute = "Sagiruddin"  (storing data in the object)
"""

class Car:
    def __init__(self, brand, color, price):
        # Here, 'brand', 'color', 'price' are PARAMETERS (local variables)
        # They only exist during __init__ execution
        
        print(f"Inside __init__:")
        print(f"  Parameter 'brand' = {brand}")
        print(f"  Parameter 'color' = {color}")
        print(f"  Parameter 'price' = {price}\n")
        
        # We assign them to 'self' to make them INSTANCE VARIABLES
        # Now they're stored in the object and last forever!
        self.brand = brand
        self.color = color
        self.price = price
        
        print(f"After assignment to 'self':")
        print(f"  self.brand = {self.brand}")
        print(f"  self.color = {self.color}")
        print(f"  self.price = {self.price}\n")


# Create an object
print("Creating car1:")
car1 = Car("Toyota", "Red", 25000)

# After __init__ ends, the parameters 'brand', 'color', 'price' are GONE
# But self.brand, self.color, self.price STILL EXIST!
print("After __init__ ends:")
print(f"  car1.brand = {car1.brand}  (STILL EXISTS)")
print(f"  car1.color = {car1.color}  (STILL EXISTS)")
print(f"  car1.price = {car1.price}  (STILL EXISTS)\n")


# ===== COMPARISON TABLE =====
print("=" * 60)
print("COMPARISON: 'name' vs 'self.name'")
print("=" * 60)
print("""
┌─────────────────────────────────────────────────────────────┐
│ 'name' (Parameter)          │ 'self.name' (Attribute)       │
├─────────────────────────────┼───────────────────────────────┤
│ Local variable              │ Instance variable (property)  │
│ Only exists in __init__     │ Exists for the whole object   │
│ Temporary (gets deleted)    │ Permanent (until object dies) │
│ Used to pass data in        │ Used to store data long-term  │
