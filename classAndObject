│ Example: name = "Ali"       │ Example: car1.brand = "Ali"  │
│ (exists only during init)   │ (exists forever)             │
└─────────────────────────────┴───────────────────────────────┘
""")


# ===== PRACTICAL EXAMPLE =====
print("\n=== PRACTICAL EXAMPLE ===\n")

class Student:
    def __init__(self, roll_no, student_name, marks):
        # Parameters (temporary)
        print(f"Parameter 'student_name' = {student_name}")
        
        # Convert to instance variables (permanent)
        self.roll_no = roll_no
        self.name = student_name  # Notice: parameter is 'student_name', attribute is 'self.name'
        self.marks = marks
        
        print(f"Instance variable 'self.name' = {self.name}\n")
    
    def display(self):
        # Can access self.name even OUTSIDE __init__
        print(f"Student: {self.name}, Roll: {self.roll_no}, Marks: {self.marks}")


# Create students
student1 = Student(101, "Sagiruddin", 95)
student2 = Student(102, "Alice", 88)

# Access instance variables from outside the class
print("Accessing instance variables AFTER __init__:\n")
student1.display()
student2.display()

print(f"\nstudent1.name = {student1.name}  ✓ Instance variable exists")
print(f"student2.name = {student2.name}  ✓ Instance variable exists")


# ===== BASIC CLASS DEFINITION =====
class Person:
    # Class variable (shared by all objects)
    species = "Homo sapiens"
    
    # Constructor (__init__) - runs when an object is created
    def __init__(self, name, occupation, networth):
        # Instance variables (unique to each object)
        self.name = name
        self.occupation = occupation
        self.networth = networth
    
    # Instance method
    def display(self):
        print(f"{self.name} is a {self.occupation}")
    
    # Another method
    def get_info(self):
        return f"Name: {self.name}, Job: {self.occupation}, Net Worth: ${self.networth}M"
    
    # Method that modifies instance variable
    def give_raise(self, amount):
        self.networth += amount
        print(f"{self.name} now has a net worth of ${self.networth}M")


# ===== CREATING OBJECTS (INSTANCES) =====
