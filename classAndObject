# ===== INHERITANCE =====
print("\n--- Inheritance (Child Class) ---")
class Developer(Person):
    def __init__(self, name, networth, programming_language):
        super().__init__(name, "Developer", networth)
        self.programming_language = programming_language
    
    def code(self):
        print(f"{self.name} is coding in {self.programming_language}")


dev = Developer("Charlie", 20, "Python")
dev.display()  # Inherited method
dev.code()     # New method


# ===== UNDERSTANDING 'self' =====
print("\n--- Understanding 'self' (like 'this' in Java) ---")

class BankAccount:
    def __init__(self, account_holder, balance):
        self.account_holder = account_holder  # self = current object
        self.balance = balance
    
    def deposit(self, amount):
        # 'self' refers to the CURRENT object calling this method
        self.balance += amount
        print(f"{self.account_holder}'s balance is now: ${self.balance}")
    
    def show_balance(self):
        # Without 'self', Python wouldn't know which object's data to use
        print(f"{self.account_holder} has ${self.balance}")


# Create multiple objects - each has its own 'self'
account1 = BankAccount("Alice", 1000)
account2 = BankAccount("Bob", 500)

print("\nWhen account1.deposit() is called, 'self' = account1:")
account1.deposit(200)  # Here, self = account1

print("\nWhen account2.deposit() is called, 'self' = account2:")
account2.deposit(300)  # Here, self = account2

print("\nShowing each account's data (self knows which one):")
account1.show_balance()  # self = account1
account2.show_balance()  # self = account2

print("\nWithout 'self', Python wouldn't know which object's data to access!")


